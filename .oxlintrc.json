{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "vue", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "import/no-unassigned-import": "off"
  },
  "ignorePatterns": ["dist", "node_modules", "src/types/database.ts", "supabase"]
}
